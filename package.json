{
  "name": "reading-time",
  "version": "1.1.0",
  "description": "A simple, lightweight plugin used to display an estimated time to read some text no dependency",
  "author": "Grzegorz Tomicki",
  "main": "dist/readingTime.js",
  "module": "dist/readingTime.esm.js",
  "types": "dist/script.d.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tomickigrzegorz/reading-time.git"
  },
  "scripts": {
    "build": "rollup -c --environment PRODUCTION && yarn build:types",
    "watch": "rollup -c -w",
    "build:types": "tsc --emitDeclarationOnly",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^8.5.0",
    "eslint": "^8.6.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^4.0.0",
    "prettier": "^2.5.1",
    "rollup": "^2.63.0",
    "rollup-plugin-cleanup": "^3.2.1",
    "rollup-plugin-livereload": "^2.0.5",
    "rollup-plugin-serve": "^1.1.0",
    "rollup-plugin-terser": "^7.0.2",
    "tslib": "^2.6.2",
    "typescript": "^4.9.5"
  }
}
